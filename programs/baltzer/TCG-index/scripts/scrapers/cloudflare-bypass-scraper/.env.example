# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# =============================================================================
# OPTION 1: Web Unlocker API (RECOMMENDED - simplest, handles Cloudflare)
# =============================================================================
# Get from: Bright Data → Web Access → Unlocker API → API Token
BRIGHTDATA_API_TOKEN=your_api_token_here

# =============================================================================
# OPTION 2: Residential Proxy (requires browser automation)
# =============================================================================
# Get from: Bright Data, Smartproxy, IPRoyal, or Oxylabs
# Format: http://username:password@host:port
PROXY_ENDPOINT=http://user:pass@proxy.example.com:port

# Optional: Run browser in headless mode (set to true for servers)
HEADLESS=false
