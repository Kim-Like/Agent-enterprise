# Supabase - get from Dashboard > Project Settings > API
SUPABASE_URL=https://yfxmbzgkuejiazkudtsf.supabase.co
# Use double quotes if the key contains = (JWT padding)
SUPABASE_SERVICE_ROLE_KEY="your_service_role_key_here"

# Optional: DRY_RUN=1 to test worker without real scraping
# DRY_RUN=1

# Optional: HEADLESS=true for CI/servers (browser visible by default to avoid Cloudflare)
# HEADLESS=true

# Residential proxy (for scrape-top-proxy)
# Bright Data: use basic username, NO -session- for IP rotation
# PROXY_ENDPOINT=http://brd-customer-XXX-zone-cardmarket:password@brd.superproxy.io:33335
# PROXY_COUNTRY=de   # Optional: EU IPs for Cardmarket (-country-de in username)
# CONSERVATIVE=1     # Ultra-conservative - used by scrape-top-proxy
# WORKERS=3          # Parallel workers (unique IP each). Default 1. Use 2-5 to speed up.

