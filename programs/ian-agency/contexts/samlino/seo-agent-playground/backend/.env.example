# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Organisation identity — injected into every generated schema
ORG_NAME=Your Organisation Name
ORG_URL=https://yourdomain.com
ORG_LOGO_URL=https://yourdomain.com/logo.png
# Comma-separated list of social profile URLs
ORG_SAME_AS=https://twitter.com/yourhandle,https://linkedin.com/company/yourco

# Claude Code binary path (optional — for portability when moving the project)
# Leave blank to auto-discover via PATH or VS Code/Cursor extension bundles.
# Find the path with:
#   find ~/.vscode ~/.cursor -name 'claude' -type f 2>/dev/null | sort | tail -1
CLAUDE_BINARY_PATH=

# FastAPI server
BACKEND_PORT=8001
# Comma-separated allowed origins for CORS
ALLOWED_ORIGINS=http://localhost:8080
