# Monorepo mode: keep these in /Users/IAn/Agent/IAn/.env (single source of truth)
# Standalone cPanel mode: you can define the same keys in this app-local .env instead.

BILLY_API_TOKEN=your_billy_access_token_here
ARTISAN_REPORTING_DB_HOST=127.0.0.1
ARTISAN_REPORTING_DB_PORT=3306
ARTISAN_REPORTING_DB_NAME=your_reporting_db
ARTISAN_REPORTING_DB_USER=your_reporting_user
ARTISAN_REPORTING_DB_PASSWORD=your_reporting_password
